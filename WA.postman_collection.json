					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
						"method": "DELETE",
						"url": { "raw": "{{base_url}}/admin/users/911234567890/hard", "host": ["{{base_url}}"], "path": ["admin", "users", "911234567890", "hard"] }
					}
