		{
			"name": "4. Multi-Node ChatFlows",
			"item": [
				{
					"name": "Create Flow (Multi-Step)",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"triggerKeyword\": \"hi\",\n    \"nodes\": [\n        { \"id\": \"1\", \"type\": \"message\", \"text\": \"Welcome 👋\" },\n        { \"id\": \"2\", \"type\": \"buttons\", \"text\": \"How can I help?\", \"buttons\": [\n            {\"text\": \"Order\", \"next\": \"3\"},\n            {\"text\": \"Support\", \"next\": \"4\"}\n        ]},\n        { \"id\": \"3\", \"type\": \"message\", \"text\": \"Ordering menu opened!\" },\n        { \"id\": \"4\", \"type\": \"message\", \"text\": \"Connecting to support...\" }\n    ]\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/whatsapp/chatflows", "host": ["{{base_url}}"], "path": ["whatsapp", "chatflows"] }
					}
				},
				{
					"name": "List ChatFlows",
