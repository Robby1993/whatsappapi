{
	"info": {
		"_postman_id": "omnichannel-messaging-v1-comprehensive",
		"name": "Omnichannel Messaging API - ALL ENDPOINTS",
		"description": "Comprehensive Postman collection for the Omnichannel Messaging API, including WhatsApp, RCS, ChatFlow, User Management, and Admin tools.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Authentication",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Test User\",\n    \"number\": \"918866813729\",\n    \"password\": \"password123\",\n    \"userType\": \"user\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] }
					}
				},
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"number\": \"918866813729\",\n    \"password\": \"password123\",\n    \"userType\": \"user\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
					}
				},
				{
					"name": "Forgot Password",
					"request": {
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"number\": \"918866813729\",\n    \"userType\": \"user\",\n    \"newPassword\": \"new_secret_pass\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/auth/forgot-password", "host": ["{{base_url}}"], "path": ["auth", "forgot-password"] }
					}
				},
				{
					"name": "Update Profile",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Updated Name\",\n    \"gender\": \"Male\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/auth/update-profile", "host": ["{{base_url}}"], "path": ["auth", "update-profile"] }
					}
				},
				{
					"name": "Buy Subscription",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"planId\": \"plan_standard_30\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/auth/buy-subscription", "host": ["{{base_url}}"], "path": ["auth", "buy-subscription"] }
					}
				}
			]
		},
		{
			"name": "2. Omnichannel API (API Key)",
			"item": [
				{
					"name": "WhatsApp - Send Text",
					"request": {
						"method": "POST",
						"header": [{ "key": "x-api-key", "value": "{{api_key}}", "type": "text" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"receiver\": \"918866813729\",\n    \"content\": \"Hello via API Key!\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/api/v1/whatsapp/send", "host": ["{{base_url}}"], "path": ["api", "v1", "whatsapp", "send"] }
					}
				},
				{
					"name": "WhatsApp - Send Media",
					"request": {
						"method": "POST",
						"header": [{ "key": "x-api-key", "value": "{{api_key}}", "type": "text" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"receiver\": \"918866813729\",\n    \"type\": \"image\",\n    \"content\": \"https://picsum.photos/500\",\n    \"metadata\": { \"caption\": \"Sent via Omnichannel V1\" }\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/api/v1/whatsapp/send", "host": ["{{base_url}}"], "path": ["api", "v1", "whatsapp", "send"] }
					}
				},
				{
					"name": "RCS - Send Text",
					"request": {
						"method": "POST",
						"header": [{ "key": "x-api-key", "value": "{{api_key}}", "type": "text" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"receiver\": \"+918866813729\",\n    \"content\": \"Hello via RCS API!\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/api/v1/rcs/send", "host": ["{{base_url}}"], "path": ["api", "v1", "rcs", "send"] }
					}
				},
				{
					"name": "RCS - Rich Card",
					"request": {
						"method": "POST",
						"header": [{ "key": "x-api-key", "value": "{{api_key}}", "type": "text" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"receiver\": \"+918866813729\",\n    \"metadata\": {\n        \"richCard\": {\n            \"standaloneCard\": {\n                \"cardContent\": {\n                    \"title\": \"Omnichannel Title\",\n                    \"description\": \"Interactive RCS card.\",\n                    \"media\": { \"height\": \"MEDIUM\", \"contentInfo\": { \"fileUrl\": \"https://picsum.photos/500\" } }\n                }\n            }\n        }\n    }\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/api/v1/rcs/rich-card", "host": ["{{base_url}}"], "path": ["api", "v1", "rcs", "rich-card"] }
					}
				},
				{
					"name": "Broadcast (Multi-channel)",
					"request": {
						"method": "POST",
						"header": [{ "key": "x-api-key", "value": "{{api_key}}", "type": "text" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"channel\": \"whatsapp\",\n    \"receivers\": [\"918866813729\", \"919988776655\"],\n    \"content\": \"Testing Omnichannel Broadcast\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/api/v1/broadcast", "host": ["{{base_url}}"], "path": ["api", "v1", "broadcast"] }
					}
				},
				{
					"name": "Get Message Status",
					"request": {
						"method": "GET",
						"header": [{ "key": "x-api-key", "value": "{{api_key}}", "type": "text" }],
						"url": { "raw": "{{base_url}}/api/v1/message/status/PASTE_MESSAGE_ID_HERE", "host": ["{{base_url}}"], "path": ["api", "v1", "message", "status", "PASTE_MESSAGE_ID_HERE"] }
					}
				}
			]
		},
		{
			"name": "3. WhatsApp Device Management",
			"item": [
				{
					"name": "Connect QR",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
						"method": "POST",
						"url": { "raw": "{{base_url}}/whatsapp/connect-qr", "host": ["{{base_url}}"], "path": ["whatsapp", "connect-qr"] }
					}
				},
				{
					"name": "Connect Pairing Code",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
						"method": "POST",
						"url": { "raw": "{{base_url}}/whatsapp/connect-pair", "host": ["{{base_url}}"], "path": ["whatsapp", "connect-pair"] }
