		}
	],
	"variable": [
		{ "key": "base_url", "value": "http://localhost:3000" },
		{ "key": "auth_token", "value": "PASTE_JWT_TOKEN_HERE" },
		{ "key": "api_key", "value": "PASTE_API_KEY_HERE" }
	]
