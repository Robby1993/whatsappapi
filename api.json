{
	"info": {
		"_postman_id": "omnichannel-messaging-v1-ultimate-v5",
		"name": "Omnichannel Messaging API - ALL ENDPOINTS",
		"description": "Complete collection for Flutter development. Includes Auth, Dashboard, Multi-node Flows, Templates (CRUD), Campaigns (CRUD), WhatsApp/RCS Messaging, and Admin tools.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Authentication",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Test User\",\n    \"number\": \"918866813729\",\n    \"password\": \"password123\",\n    \"userType\": \"user\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] }
					}
				},
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"number\": \"918866813729\",\n    \"password\": \"password123\",\n    \"userType\": \"user\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
					}
				}
			]
		},
		{
			"name": "2. Dashboard & Stats",
			"item": [
				{
					"name": "User Dashboard",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
						"method": "GET",
						"url": { "raw": "{{base_url}}/admin/dashboard", "host": ["{{base_url}}"], "path": ["admin", "dashboard"] }
					}
				}
			]
		},
		{
			"name": "3. Templates (CRUD)",
			"item": [
				{
					"name": "Create Template",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"keyword\": \"welcome_offer\",\n    \"type\": \"text\",\n    \"content\": \"Hello! Welcome to our store. Use code WELCOME10 for 10% off.\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/templates", "host": ["{{base_url}}"], "path": ["templates"] }
					}
				},
				{
					"name": "List All Templates",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
						"method": "GET",
						"url": { "raw": "{{base_url}}/templates", "host": ["{{base_url}}"], "path": ["templates"] }
					}
				},
				{
					"name": "Get Template",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
						"method": "GET",
						"url": { "raw": "{{base_url}}/templates/welcome_offer", "host": ["{{base_url}}"], "path": ["templates", "welcome_offer"] }
					}
				},
				{
					"name": "Update Template",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
						"method": "PUT",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"content\": \"Hello! Welcome to our updated store. Use code WELCOME20 for 20% off.\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/templates/welcome_offer", "host": ["{{base_url}}"], "path": ["templates", "welcome_offer"] }
					}
				},
				{
					"name": "Delete Template",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
						"method": "DELETE",
						"url": { "raw": "{{base_url}}/templates/welcome_offer", "host": ["{{base_url}}"], "path": ["templates", "welcome_offer"] }
					}
				}
			]
		},
		{
			"name": "4. Campaigns (CRUD)",
