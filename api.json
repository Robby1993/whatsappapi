{
	"info": {
		"_postman_id": "omnichannel-messaging-v1-ultimate",
		"name": "Omnichannel Messaging API - COMPLETE",
		"description": "The complete Postman collection for the Omnichannel Messaging API. Includes WhatsApp, RCS, Multi-node ChatFlows, Campaigns, User Subscriptions, and full Admin Management.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Authentication",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Test User\",\n    \"number\": \"918866813729\",\n    \"password\": \"password123\",\n    \"userType\": \"user\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] }
					}
				},
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"number\": \"918866813729\",\n    \"password\": \"password123\",\n    \"userType\": \"user\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
					}
				},
				{
					"name": "Update Profile",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Updated Name\",\n    \"gender\": \"Male\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/auth/update-profile", "host": ["{{base_url}}"], "path": ["auth", "update-profile"] }
					}
				},
				{
					"name": "Buy Subscription",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"planId\": \"plan_gold_30\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/auth/buy-subscription", "host": ["{{base_url}}"], "path": ["auth", "buy-subscription"] }
					}
				}
			]
		},
		{
			"name": "2. Omnichannel API (API Key Auth)",
			"item": [
				{
					"name": "WhatsApp - Send Text",
					"request": {
						"method": "POST",
						"header": [{ "key": "x-api-key", "value": "{{api_key}}", "type": "text" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"receiver\": \"918866813729\",\n    \"content\": \"Hello via API Key!\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/api/v1/whatsapp/send", "host": ["{{base_url}}"], "path": ["api", "v1", "whatsapp", "send"] }
					}
				},
				{
					"name": "WhatsApp - Broadcast",
					"request": {
						"method": "POST",
						"header": [{ "key": "x-api-key", "value": "{{api_key}}", "type": "text" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"receivers\": [\"918866813729\", \"919988776655\"],\n    \"content\": \"Bulk Omnichannel message!\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/api/v1/whatsapp/broadcast", "host": ["{{base_url}}"], "path": ["api", "v1", "whatsapp", "broadcast"] }
					}
				},
				{
					"name": "RCS - Send Text",
					"request": {
						"method": "POST",
						"header": [{ "key": "x-api-key", "value": "{{api_key}}", "type": "text" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"receiver\": \"+918866813729\",\n    \"content\": \"Hello via RCS API!\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/api/v1/rcs/send", "host": ["{{base_url}}"], "path": ["api", "v1", "rcs", "send"] }
					}
				},
				{
					"name": "RCS - Send Media",
					"request": {
						"method": "POST",
						"header": [{ "key": "x-api-key", "value": "{{api_key}}", "type": "text" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"receiver\": \"+918866813729\",\n    \"type\": \"image\",\n    \"content\": \"https://picsum.photos/800/600\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/api/v1/rcs/media", "host": ["{{base_url}}"], "path": ["api", "v1", "rcs", "media"] }
					}
				},
				{
					"name": "RCS - Rich Card",
					"request": {
						"method": "POST",
						"header": [{ "key": "x-api-key", "value": "{{api_key}}", "type": "text" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"receiver\": \"+918866813729\",\n    \"metadata\": {\n        \"richCard\": {\n            \"standaloneCard\": {\n                \"cardContent\": {\n                    \"title\": \"Special Deal!\",\n                    \"description\": \"50% off today!\",\n                    \"media\": { \"height\": \"MEDIUM\", \"contentInfo\": { \"fileUrl\": \"https://picsum.photos/600/400\" } },\n                    \"suggestions\": [\n                        { \"reply\": { \"text\": \"Buy Now\", \"postbackData\": \"buy_now\" } }\n                    ]\n                }\n            }\n        }\n    }\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/api/v1/rcs/rich-card", "host": ["{{base_url}}"], "path": ["api", "v1", "rcs", "rich-card"] }
					}
				},
				{
					"name": "Universal Message Status",
					"request": {
						"method": "GET",
						"header": [{ "key": "x-api-key", "value": "{{api_key}}", "type": "text" }],
						"url": { "raw": "{{base_url}}/api/v1/message/status/PASTE_ID_HERE", "host": ["{{base_url}}"], "path": ["api", "v1", "message", "status", "PASTE_ID_HERE"] }
					}
				}
			]
		},
