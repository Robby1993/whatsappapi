					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
						"method": "GET",
						"url": { "raw": "{{base_url}}/whatsapp/session-status", "host": ["{{base_url}}"], "path": ["whatsapp", "session-status"] }
