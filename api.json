						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Marketing Launch\",\n    \"message\": \"Our new product is live! Check it out at https://example.com\",\n    \"numbers\": [\"918866813729\", \"919988776655\"]\n}",
							"options": { "raw": { "language": "json" } }
