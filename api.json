					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
						"method": "DELETE",
						"url": { "raw": "{{base_url}}/whatsapp/chatflows/1", "host": ["{{base_url}}"], "path": ["whatsapp", "chatflows", "1"] }
					}
				}
			]
		},
