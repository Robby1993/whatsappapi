{
	"info": {
		"_postman_id": "omnichannel-messaging-v1-ultimate-v3",
		"name": "Omnichannel Messaging API - ALL ENDPOINTS",
		"description": "Complete collection for Flutter development. Includes Auth, Dashboard, Multi-node Flows, Campaigns, WhatsApp/RCS Messaging, and Admin tools.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Authentication",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Test User\",\n    \"number\": \"918866813729\",\n    \"password\": \"password123\",\n    \"userType\": \"user\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] }
					}
				},
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"number\": \"918866813729\",\n    \"password\": \"password123\",\n    \"userType\": \"user\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
					}
				}
			]
		},
		{
			"name": "2. Dashboard & Stats",
			"item": [
				{
					"name": "User Dashboard",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
						"method": "GET",
						"url": { "raw": "{{base_url}}/admin/dashboard", "host": ["{{base_url}}"], "path": ["admin", "dashboard"] },
						"description": "Primary endpoint for Flutter main screen. Returns message metrics, flow stats, subscription days, and recent activity."
					}
				},
				{
					"name": "Admin Global Stats",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
						"method": "GET",
						"url": { "raw": "{{base_url}}/admin/stats", "host": ["{{base_url}}"], "path": ["admin", "stats"] },
						"description": "Admin only: Bird's eye view of total users and messages across the entire system."
					}
				}
			]
		},
		{
			"name": "3. Omnichannel Messaging (API Key)",
			"item": [
				{
					"name": "WhatsApp - Send Text",
					"request": {
						"method": "POST",
						"header": [{ "key": "x-api-key", "value": "{{api_key}}", "type": "text" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"receiver\": \"918866813729\",\n    \"content\": \"Hello via API Key!\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/api/v1/whatsapp/send", "host": ["{{base_url}}"], "path": ["api", "v1", "whatsapp", "send"] }
					}
				},
				{
					"name": "RCS - Send Text",
					"request": {
						"method": "POST",
						"header": [{ "key": "x-api-key", "value": "{{api_key}}", "type": "text" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"receiver\": \"+918866813729\",\n    \"content\": \"Hello via RCS API!\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/api/v1/rcs/send", "host": ["{{base_url}}"], "path": ["api", "v1", "rcs", "send"] }
					}
				}
			]
		},
		{
			"name": "4. Flow Management",
			"item": [
				{
					"name": "Create Multi-node Flow",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Welcome Flow\",\n    \"trigger\": \"hi\",\n    \"nodes\": [\n        {\n            \"id\": \"1\",\n            \"type\": \"text\",\n            \"data\": { \"text\": \"Hello 👋 Welcome!\" },\n            \"next\": \"2\"\n        },\n        {\n            \"id\": \"2\",\n            \"type\": \"buttons\",\n            \"data\": {\n                \"text\": \"How can I help?\",\n                \"buttons\": [\n                    { \"id\": \"order\", \"title\": \"📦 Order\", \"next\": \"3\" },\n                    { \"id\": \"support\", \"title\": \"🛠 Support\", \"next\": \"4\" }\n                ]\n            }\n        },\n        { \"id\": \"3\", \"type\": \"text\", \"data\": { \"text\": \"Opening menu...\" } },\n        { \"id\": \"4\", \"type\": \"text\", \"data\": { \"text\": \"Connecting to agent...\" } }\n    ]\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/flows", "host": ["{{base_url}}"], "path": ["flows"] }
					}
				},
				{
					"name": "List All My Flows",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
						"method": "GET",
						"url": { "raw": "{{base_url}}/flows", "host": ["{{base_url}}"], "path": ["flows"] }
					}
				}
			]
		},
		{
			"name": "5. Device Management",
			"item": [
				{
					"name": "Connect via QR",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
						"method": "POST",
						"url": { "raw": "{{base_url}}/whatsapp/connect-qr", "host": ["{{base_url}}"], "path": ["whatsapp", "connect-qr"] }
					}
				},
				{
					"name": "Session Status",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
						"method": "GET",
						"url": { "raw": "{{base_url}}/whatsapp/session-status", "host": ["{{base_url}}"], "path": ["whatsapp", "session-status"] }
					}
				}
			]
		},
		{
			"name": "6. Admin Panel",
			"item": [
				{
					"name": "Generate API Key",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
						"method": "POST",
						"url": { "raw": "{{base_url}}/admin/users/918866813729/generate-api-key", "host": ["{{base_url}}"], "path": ["admin", "users", "918866813729", "generate-api-key"] }
					}
				},
				{
					"name": "List All Users",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
						"method": "GET",
						"url": { "raw": "{{base_url}}/admin/users", "host": ["{{base_url}}"], "path": ["admin", "users"] }
					}
				}
			]
		}
	],
	"variable": [
		{ "key": "base_url", "value": "http://localhost:3000" },
		{ "key": "auth_token", "value": "PASTE_JWT_TOKEN_HERE" },
		{ "key": "api_key", "value": "PASTE_API_KEY_HERE" }
	]
}
