					"name": "Delete Campaign",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
						"method": "DELETE",
						"url": { "raw": "{{base_url}}/campaigns/1", "host": ["{{base_url}}"], "path": ["campaigns", "1"] }
					}
				}
			]
		},
		{
			"name": "5. Flow Management (Multi-Node)",
			"item": [
				{
					"name": "Create Flow",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Support Flow\",\n    \"trigger\": \"help\",\n    \"nodes\": [\n        { \"id\": \"1\", \"type\": \"text\", \"data\": { \"text\": \"How can we help?\" }, \"next\": \"2\" },\n        { \"id\": \"2\", \"type\": \"buttons\", \"data\": { \"text\": \"Select option\", \"buttons\": [{\"id\":\"opt1\",\"title\":\"Order\"}, {\"id\":\"opt2\",\"title\":\"Chat\"}]} }\n    ]\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/flows", "host": ["{{base_url}}"], "path": ["flows"] }
					}
				},
				{
					"name": "List All Flows",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }] },
						"method": "GET",
						"url": { "raw": "{{base_url}}/flows", "host": ["{{base_url}}"], "path": ["flows"] }
					}
				}
			]
		},
		{
			"name": "6. Omnichannel Messaging (API Key)",
			"item": [
				{
					"name": "WhatsApp - Send Text",
					"request": {
						"method": "POST",
						"header": [{ "key": "x-api-key", "value": "{{api_key}}", "type": "text" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"receiver\": \"918866813729\",\n    \"content\": \"Hello via API Key!\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/api/v1/whatsapp/send", "host": ["{{base_url}}"], "path": ["api", "v1", "whatsapp", "send"] }
					}
				},
				{
					"name": "RCS - Send Text",
					"request": {
						"method": "POST",
						"header": [{ "key": "x-api-key", "value": "{{api_key}}", "type": "text" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"receiver\": \"+918866813729\",\n    \"content\": \"Hello via RCS API!\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/api/v1/rcs/send", "host": ["{{base_url}}"], "path": ["api", "v1", "rcs", "send"] }
					}
				}
			]
		},
